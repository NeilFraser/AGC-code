# Unit tests for the Boolean functions.

# TEST: NOT

	CA	NUM0		# NOT 0 -> 1
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM1		# NOT 1 -> 0
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM6		# NOT 6 -> 0
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL


# TEST: ==, !=, <, >, <=, >=
# Although these tests only check for conditions that output 0,
# that's still comprehensive since half of them use BL-NOT.

	TCR	TSBL_33		# 3 != 3 -> 0
	TCR	MA-SU
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_33		# 3 > 3 -> 0
	TCR	MA-SU
	TCR	BL-GT
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_33		# 3 < 3 -> 0
	TCR	MA-SU
	TCR	BL-LT
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL


	TCR	TSBL_00		# +0 != -0 -> 0
	TCR	MA-SU
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_00		# +0 > -0 -> 0
	TCR	MA-SU
	TCR	BL-GT
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_00		# +0 < -0 -> 0
	TCR	MA-SU
	TCR	BL-LT
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL


	TCR	TSBL_36		# 3 == 6 -> 0
	TCR	MA-SU
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_36		# 3 >= 6 -> 0
	TCR	MA-SU
	TCR	BL-LT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_36		# 3 > 6 -> 0
	TCR	MA-SU
	TCR	BL-GT
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL


	TCR	TSBL_71		# 7 == 1 -> 0
	TCR	MA-SU
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_71		# 7 <= 1 -> 0
	TCR	MA-SU
	TCR	BL-GT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	TCR	TSBL_71		# 7 < 1 -> 0
	TCR	MA-SU
	TCR	BL-LT
	TCR	BL-NOT
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL


# TEST: OR

	CA	NUM0		# 0 OR 0 -> 0
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	BL-OR
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM0		# 0 OR 1 -> 1
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	BL-OR
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM1		# 1 OR 0 -> 1
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	BL-OR
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM1		# 1 OR 1 -> 1
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	BL-OR
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	TS-EQUAL


# TEST: AND

	CA	NUM0		# 0 AND 0 -> 0
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	BL-AND
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM0		# 0 AND 1 -> 0
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	BL-AND
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM1		# 1 AND 0 -> 0
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	BL-AND
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM1		# 1 AND 1 -> 1
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	BL-AND
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	TCR	TS-EQUAL


# TEST: Conditional operator (a ? b : c)

	CA	NUM7		# 0 ? 3 : 7 = 7
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	BL-COND
	TCR	PUSH
	CA	NUM7
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM7		# 2 ? 3 : 7 = 3
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	CA	NUM2
	TCR	PUSH
	TCR	BL-COND
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	TCR	TS-EQUAL

	TCF	TSBL-END	# Skip execution past the private functions.


TSBL_33	EXTEND
	QXCH L
	CA	NUM3		# Load 3 and 3 onto the stack.
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	EXTEND
	QXCH L
	RETURN

TSBL_00	EXTEND
	QXCH L
	CA	NUM0		# Load +0 and -0 onto the stack.
	TCR	PUSH
	CA	NUM0
	COM
	TCR	PUSH
	EXTEND
	QXCH L
	RETURN

TSBL_36	EXTEND
	QXCH L
	CA	NUM3		# Load 3 and 6 onto the stack.
	TCR	PUSH
	CA	NUM6
	TCR	PUSH
	EXTEND
	QXCH L
	RETURN

TSBL_71	EXTEND
	QXCH L
	CA	NUM7		# Load 7 and 1 onto the stack.
	TCR	PUSH
	CA	NUM1
	TCR	PUSH
	EXTEND
	QXCH L
	RETURN

TSBL-END NOOP
