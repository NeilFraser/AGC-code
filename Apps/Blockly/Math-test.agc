# Unit tests for the Math functions.

# TEST: ADD

	CA	NUM1		# 1 + 2 -> 3
	TCR	PUSH
	CA	NUM2
	TCR	PUSH
	TCR	MA-AD
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	TCR	TS-EQUAL

	CA	NUM3		# -3 + 3 -> 0
	COM
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	TCR	MA-AD
	TCR	PUSH
	CA	NUM0
	TCR	PUSH
	TCR	TS-EQUAL


# TEST: SUBTRACT

	CA	NUM3		# 5 - 3 -> 2
	TCR	PUSH
	CA	NUM5
	TCR	PUSH
	TCR	MA-SU
	TCR	PUSH
	CA	NUM2
	TCR	PUSH
	TCR	TS-EQUAL


# TEST: MULTIPLY

	CA	NUM2		# 2 * 3 -> 6
	TCR	PUSH
	CA	NUM3
	TCR	PUSH
	TCR	MA-MP
	TCR	PUSH
	CA	NUM6
	TCR	PUSH
	TCR	TS-EQUAL
